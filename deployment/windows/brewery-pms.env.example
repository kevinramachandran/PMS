# Copy this file to C:\Brewery-PMS\config\brewery-pms.env and replace the sample values.

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
APP_TIMEZONE=UTC

DB_URL=jdbc:mysql://db-host:3306/brewery_pms?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=brewery_user
DB_PASSWORD=replace-me

LOG_LEVEL_ROOT=INFO
LOG_LEVEL_WEB=INFO
LOG_FILE=C:\Brewery-PMS\logs\brewery-pms.log

UPLOAD_DIR=C:\Brewery-PMS\uploads\footer-buttons
APP_EMAIL_CONFIG_SECRET=replace-me
APP_EMAIL_CONFIG_TEST_RATE_LIMIT_MS=5000